<Window x:Class="SURS.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SURS.App"
        xmlns:converters="clr-namespace:SURS.App.Converters"
        xmlns:helpers="clr-namespace:SURS.App.Helpers"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="SURS 妇科超声结构化报告系统" Height="950" Width="1800"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F8F9FA" FontFamily="Segoe UI, Microsoft YaHei UI, sans-serif"
        PreviewKeyDown="Window_PreviewKeyDown"
        Loaded="Window_Loaded">

    <Window.Resources>
        <converters:RadioBoolConverter x:Key="RadioBoolConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:RadioToVisibilityConverter x:Key="RadioToVis"/>
        <converters:ImageIndexConverter x:Key="ImageIndexConverter"/>

        <!-- COLOR PALETTE: Modern Medical Theme -->
        <Color x:Key="Color.Primary">#4A90E2</Color>       <!-- Modern Blue -->
        <Color x:Key="Color.PrimaryDark">#357ABD</Color>   <!-- Darker Blue -->
        <Color x:Key="Color.PrimaryLight">#6BA3E8</Color>  <!-- Light Blue -->
        <Color x:Key="Color.Accent">#50C878</Color>        <!-- Medical Green -->
        <Color x:Key="Color.AccentLight">#E8F5E9</Color>   <!-- Light Green Background -->
        <Color x:Key="Color.Background">#F8F9FA</Color>    <!-- Soft Gray Background -->
        <Color x:Key="Color.Surface">#FFFFFF</Color>
        <Color x:Key="Color.SurfaceElevated">#FFFFFF</Color>
        <Color x:Key="Color.TextPrimary">#1A1A1A</Color>   <!-- Deep Black -->
        <Color x:Key="Color.TextSecondary">#6C757D</Color> <!-- Medium Gray -->
        <Color x:Key="Color.TextTertiary">#ADB5BD</Color>   <!-- Light Gray -->
        <Color x:Key="Color.Border">#E9ECEF</Color>        <!-- Soft Border -->
        <Color x:Key="Color.BorderLight">#F1F3F5</Color>   <!-- Very Light Border -->
        <Color x:Key="Color.Error">#DC3545</Color>
        <Color x:Key="Color.Warning">#FFC107</Color>
        <Color x:Key="Color.Success">#28A745</Color>
        <Color x:Key="Color.Info">#17A2B8</Color>

        <SolidColorBrush x:Key="Brush.Primary" Color="{StaticResource Color.Primary}"/>
        <SolidColorBrush x:Key="Brush.PrimaryDark" Color="{StaticResource Color.PrimaryDark}"/>
        <SolidColorBrush x:Key="Brush.PrimaryLight" Color="{StaticResource Color.PrimaryLight}"/>
        <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}"/>
        <SolidColorBrush x:Key="Brush.AccentLight" Color="{StaticResource Color.AccentLight}"/>
        <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}"/>
        <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}"/>
        <SolidColorBrush x:Key="Brush.SurfaceElevated" Color="{StaticResource Color.SurfaceElevated}"/>
        <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}"/>
        <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}"/>
        <SolidColorBrush x:Key="Brush.TextTertiary" Color="{StaticResource Color.TextTertiary}"/>
        <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}"/>
        <SolidColorBrush x:Key="Brush.BorderLight" Color="{StaticResource Color.BorderLight}"/>
        
        <!-- Gradient Brushes -->
        <LinearGradientBrush x:Key="Brush.PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource Color.Primary}" Offset="0"/>
            <GradientStop Color="{StaticResource Color.PrimaryDark}" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="Brush.HeaderGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#5A9FE8" Offset="0"/>
            <GradientStop Color="#4A90E2" Offset="1"/>
        </LinearGradientBrush>

        <!-- TYPOGRAPHY -->
        <Style x:Key="Text.H1" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="Text.H2" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="Text.H3" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="Text.Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <Style x:Key="Text.LabelSecondary" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="Text.Unit" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextTertiary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
        </Style>

        <Style x:Key="Text.Caption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextTertiary}"/>
            <Setter Property="LineHeight" Value="16"/>
        </Style>

        <!-- COMPONENTS -->
        
        <!-- Card -->
        <Style x:Key="Card" TargetType="ContentControl">
            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
            <Setter Property="Padding" Value="32"/>
            <Setter Property="Margin" Value="0,0,0,28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" BorderBrush="{StaticResource Brush.BorderLight}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="0" BlurRadius="20" Opacity="0.08"/>
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CollapsibleCard" TargetType="Expander">
            <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
            <Setter Property="Padding" Value="32"/>
            <Setter Property="Margin" Value="0,0,0,28"/>
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" BorderBrush="{StaticResource Brush.BorderLight}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="0" BlurRadius="20" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <ToggleButton x:Name="HeaderSite"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                              BorderThickness="0"
                                              Background="{StaticResource Brush.Primary}"
                                              Padding="16,12"
                                              Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Grid.Column="0" ContentSource="Header" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="Chevron" Grid.Column="1" Text="▼" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </Grid>
                                </ToggleButton>

                                <ContentPresenter x:Name="ExpandSite" ContentSource="Content" Margin="{TemplateBinding Padding}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="Chevron" Property="Text" Value="▶"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Section Header -->
        <Style x:Key="SectionHeader" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Primary}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,24"/>
        </Style>

        <!-- TextBox: Modern, Clean -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="Background" Value="#FAFBFC"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Brush.Primary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource Brush.PrimaryLight}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource Brush.Primary}"/>
                                <Setter Property="Background" TargetName="border" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom ScrollBar Style -->
        <Style x:Key="ModernScrollBar" TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextTertiary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="GridRoot" Width="10" Background="{TemplateBinding Background}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.00001*"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="0" IsDirectionReversed="true" Focusable="false">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="{TemplateBinding Foreground}" Style="{DynamicResource ScrollBarThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="PageUp" Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="false"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="PageDown" Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="false"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="GridRoot" Property="Width" Value="Auto"/>
                                <Setter TargetName="GridRoot" Property="Height" Value="10"/>
                                <Setter TargetName="Thumb" Property="Tag" Value="Horizontal"/>
                                <Setter TargetName="PageDown" Property="Command" Value="ScrollBar.PageLeftCommand"/>
                                <Setter TargetName="PageUp" Property="Command" Value="ScrollBar.PageRightCommand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="rectangle"
                                Background="{TemplateBinding Background}"
                                Height="{TemplateBinding Height}"
                                SnapsToDevicePixels="True"
                                Width="{TemplateBinding Width}"
                                CornerRadius="5"
                                Opacity="0.4"
                                Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="rectangle" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="true">
                                <Setter TargetName="rectangle" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ScrollViewer Style -->
        <Style x:Key="ModernScrollViewer" TargetType="{x:Type ScrollViewer}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid x:Name="Grid" Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Rectangle x:Name="Corner" Grid.Column="1" Fill="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" Grid.Row="1"/>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" CanContentScroll="{TemplateBinding CanContentScroll}" CanHorizontallyScroll="False" Grid.Column="0" Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" Margin="{TemplateBinding Padding}" Grid.Row="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" AutomationProperties.AutomationId="VerticalScrollBar" Cursor="Arrow" Grid.Column="1" Maximum="{TemplateBinding ScrollableHeight}" Minimum="0" Grid.Row="0" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" ViewportSize="{TemplateBinding ViewportHeight}" Style="{StaticResource ModernScrollBar}"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar" AutomationProperties.AutomationId="HorizontalScrollBar" Cursor="Arrow" Grid.Column="0" Maximum="{TemplateBinding ScrollableWidth}" Minimum="0" Orientation="Horizontal" Grid.Row="1" Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" ViewportSize="{TemplateBinding ViewportWidth}" Style="{StaticResource ModernScrollBar}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- RadioButton: Modern Chip Style -->
        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,10,8"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="#F8F9FA" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1.5" CornerRadius="8" Padding="{TemplateBinding Padding}" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{StaticResource Brush.TextPrimary}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Brush.Primary}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Brush.Primary}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="border" Property="TextElement.Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Brush.Primary}"/>
                                <Setter TargetName="border" Property="Background" Value="#E8F2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox: Modern Box -->
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="border" Width="20" Height="20" CornerRadius="5" BorderBrush="{StaticResource Brush.Border}" BorderThickness="2" Background="White" Margin="0,0,10,0">
                                <Path x:Name="check" Data="M4,10 L8,14 L16,6" Stroke="White" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Brush.Primary}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Brush.Primary}"/>
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Brush.Primary}"/>
                                <Setter TargetName="border" Property="Background" Value="#E8F2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button: Primary -->
        <Style x:Key="Button.Primary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush.Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="32,12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Brush.PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Button: Secondary -->
        <Style x:Key="Button.Secondary" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8F9FA"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Brush.Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource Brush.HeaderGradient}" Padding="32,20">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.15"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="44" Height="44" CornerRadius="10" Background="White" Margin="0,0,16,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.1"/>
                        </Border.Effect>
                        <TextBlock Text="S" Foreground="{StaticResource Brush.Primary}" FontWeight="Bold" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SURS 结构化超声报告" Foreground="White" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="妇科超声结构化报告系统" Foreground="White" FontSize="12" Opacity="0.85" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding Report.HospitalName}" Foreground="White" FontSize="15" Opacity="0.95" Margin="0,0,24,0" VerticalAlignment="Center" FontWeight="Medium"/>
                    
                    <!-- Date Display -->
                    <Border Background="#20FFFFFF" CornerRadius="16" Padding="16,6" Margin="0,0,16,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Source={x:Static system:DateTime.Now}, StringFormat='yyyy-MM-dd'}" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Toggle Preview Button -->
                    <Button Command="{Binding TogglePreviewCommand}" 
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Padding="0"
                            VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="#30FFFFFF" CornerRadius="16" Padding="16,6">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock x:Name="BtnIcon" Text="✕" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="BtnText" Text="关闭预览" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsPreviewVisible}" Value="False">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#FFFFFF"/>
                                        <Setter TargetName="BtnIcon" Property="Text" Value="👁"/>
                                        <Setter TargetName="BtnIcon" Property="Foreground" Value="{StaticResource Brush.Primary}"/>
                                        <Setter TargetName="BtnText" Property="Text" Value="显示预览"/>
                                        <Setter TargetName="BtnText" Property="Foreground" Value="{StaticResource Brush.Primary}"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content - Split View: Form and Preview -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="5" x:Name="SplitterColumn"> <!-- Splitter -->
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPreviewVisible}" Value="False">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition Width="0.75*" MinWidth="300" MaxWidth="1000" x:Name="PreviewColumn">
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="0.75*"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPreviewVisible}" Value="False">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>

            <!-- Left: Form -->
            <ScrollViewer Grid.Column="0" Padding="0,40" Background="{StaticResource Brush.Background}" Style="{StaticResource ModernScrollViewer}">
                <StackPanel MaxWidth="1000" HorizontalAlignment="Center">

                <!-- 报告头部与基础信息 -->
                <Expander Style="{StaticResource CollapsibleCard}">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="4" Height="24" Background="White" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="报告头部与基础信息" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="机构名称：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                <TextBox Text="{Binding Report.HospitalName, UpdateSourceTrigger=PropertyChanged}" Width="300" Margin="0,0,12,0"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="登记号：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                            <TextBox Text="{Binding Report.RegistrationNo, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1"/>
                            
                            <TextBlock Text="序号：" Style="{StaticResource Text.Label}" Grid.Column="3"/>
                            <TextBox Text="{Binding Report.SerialNo, UpdateSourceTrigger=PropertyChanged}" Grid.Column="4"/>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="姓名：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                            <TextBox Text="{Binding Report.PatientName, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1"/>
                            
                            <TextBlock Text="性别：" Style="{StaticResource Text.Label}" Grid.Column="3"/>
                            <ComboBox SelectedValue="{Binding Report.Gender, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Grid.Column="4" Height="38" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="女"/>
                                <ComboBoxItem Content="男"/>
                            </ComboBox>
                            
                            <TextBlock Text="年龄：" Style="{StaticResource Text.Label}" Grid.Column="6"/>
                            <TextBox Text="{Binding Report.Age, UpdateSourceTrigger=PropertyChanged}" Grid.Column="7"/>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="科别：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                            <TextBox Text="{Binding Report.Department, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1"/>

                            <TextBlock Text="门诊号：" Style="{StaticResource Text.Label}" Grid.Column="3"/>
                            <TextBox Text="{Binding Report.OutpatientNo, UpdateSourceTrigger=PropertyChanged}" Grid.Column="4"/>
                            
                            <TextBlock Text="住院号：" Style="{StaticResource Text.Label}" Grid.Column="6"/>
                            <TextBox Text="{Binding Report.InpatientNo, UpdateSourceTrigger=PropertyChanged}" Grid.Column="7"/>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="床位：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                            <TextBox Text="{Binding Report.BedNo, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1"/>
                            
                            <TextBlock Text="申请医师：" Style="{StaticResource Text.Label}" Grid.Column="3"/>
                            <TextBox Text="{Binding Report.ApplyingPhysician, UpdateSourceTrigger=PropertyChanged}" Grid.Column="4"/>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="检查项目：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                            <ComboBox SelectedValue="{Binding Report.ExamItem, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Grid.Column="1" Height="38" VerticalContentAlignment="Center">
                                <ComboBoxItem Content="经阴道彩色多普勒超声检查"/>
                                <ComboBoxItem Content="经腹部彩色多普勒超声检查"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="报告标题：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                            <TextBlock Text="妇科超声结构化报告" Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </Grid>

                        <!-- 末次月经时间 (LMP) -->
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="末次月经时间 (LMP)：" Style="{StaticResource Text.Label}" Grid.Column="0" VerticalAlignment="Center"/>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                                <ComboBox ItemsSource="{Binding Report.AvailableYears}" 
                                          SelectedValue="{Binding Report.LmpYear}" 
                                          Width="100" Height="38" 
                                          VerticalContentAlignment="Center" 
                                          Margin="0,0,8,0"/>
                                <TextBlock Text="年" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="15"/>
                                
                                <ComboBox ItemsSource="{Binding Report.AvailableMonths}" 
                                          SelectedValue="{Binding Report.LmpMonth}" 
                                          Width="80" Height="38" 
                                          VerticalContentAlignment="Center" 
                                          Margin="0,0,8,0"/>
                                <TextBlock Text="月" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="15"/>
                                
                                <ComboBox ItemsSource="{Binding Report.AvailableDays}" 
                                          SelectedValue="{Binding Report.LmpDay}" 
                                          Width="80" Height="38" 
                                          VerticalContentAlignment="Center" 
                                          Margin="0,0,8,0"/>
                                <TextBlock Text="日" VerticalAlignment="Center" FontSize="15"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="图像：" Style="{StaticResource Text.Label}" Grid.Column="0" VerticalAlignment="Top" Margin="0,8,0,0"/>
                            <StackPanel Grid.Column="1">
                                <Button Content="📷 选择图片" Command="{Binding SelectImageCommand}" Style="{StaticResource Button.Secondary}" HorizontalAlignment="Left" Margin="0,0,0,16" FontSize="14"/>
                                <StackPanel Orientation="Horizontal">
                                    <ItemsControl ItemsSource="{Binding Report.ImagePaths}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                                    <TextBlock Margin="0,0,8,0" VerticalAlignment="Center">
                                                        <TextBlock.Text>
                                                            <MultiBinding Converter="{StaticResource ImageIndexConverter}">
                                                                <Binding RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                <Binding/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    <Border CornerRadius="4" ClipToBounds="True" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                                                        <Image Source="{Binding}" Height="60" Width="60" Stretch="UniformToFill"/>
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- 子宫部分 -->
                <Expander Style="{StaticResource CollapsibleCard}">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="4" Height="24" Background="White" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="子宫部分" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel>

                        <!-- 子宫基本声像 -->
                        <Border Background="#F0F7FF" CornerRadius="8" Padding="16,12" Margin="0,0,0,20">
                            <TextBlock Text="子宫基本声像" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource Brush.Primary}"/>
                        </Border>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="子宫位置：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                <RadioButton GroupName="UterusPos" Content="前位" IsChecked="{Binding Report.Uterus.Position, Converter={StaticResource RadioBoolConverter}, ConverterParameter=前位}"/>
                                <RadioButton GroupName="UterusPos" Content="后位" IsChecked="{Binding Report.Uterus.Position, Converter={StaticResource RadioBoolConverter}, ConverterParameter=后位}"/>
                                <RadioButton GroupName="UterusPos" Content="中位" IsChecked="{Binding Report.Uterus.Position, Converter={StaticResource RadioBoolConverter}, ConverterParameter=中位}"/>
                            </WrapPanel>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="子宫体大小：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                <TextBox helpers:TextBoxHelpers.IsNumeric="True" Text="{Binding Report.Uterus.Length, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                <TextBlock Text="×" Margin="4,0"/>
                                <TextBox helpers:TextBoxHelpers.IsNumeric="True" Text="{Binding Report.Uterus.APDiameter, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                <TextBlock Text="×" Margin="4,0"/>
                                <TextBox helpers:TextBoxHelpers.IsNumeric="True" Text="{Binding Report.Uterus.Width, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                <TextBlock Text="cm" Style="{StaticResource Text.Unit}" Margin="4,0,0,0"/>
                                <TextBlock Text="（长径、前后径、横径）" Style="{StaticResource Text.Unit}" FontSize="11" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="子宫颈大小：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                <TextBox helpers:TextBoxHelpers.IsNumeric="True" Text="{Binding Report.Uterus.CervixLength, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                <TextBlock Text="×" Margin="4,0"/>
                                <TextBox helpers:TextBoxHelpers.IsNumeric="True" Text="{Binding Report.Uterus.CervixAP, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                <TextBlock Text="cm" Style="{StaticResource Text.Unit}" Margin="4,0,0,0"/>
                                <TextBlock Text="（长径、前后径）" Style="{StaticResource Text.Unit}" FontSize="11" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="子宫肌层回声：" Style="{StaticResource Text.Label}" Margin="0,0,0,8"/>
                        <StackPanel Margin="0,0,0,12">
                            <RadioButton GroupName="MyometriumEcho" Content="均匀" IsChecked="{Binding Report.Uterus.MyometriumEcho, Converter={StaticResource RadioBoolConverter}, ConverterParameter=均匀}" Margin="0,0,0,8"/>
                            
                            <StackPanel>
                                <RadioButton GroupName="MyometriumEcho" Content="不均" IsChecked="{Binding Report.Uterus.MyometriumEcho, Converter={StaticResource RadioBoolConverter}, ConverterParameter=不均}" x:Name="RbNonUniform"/>
                                
                                <!-- Non-uniform Options -->
                                <StackPanel Margin="24,8,0,0" Visibility="{Binding IsChecked, ElementName=RbNonUniform, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <CheckBox Content="局限性增厚" IsChecked="{Binding Report.Uterus.MyometriumThickeningFocal}" Margin="0,0,16,0"/>
                                        <CheckBox Content="弥漫性增厚" IsChecked="{Binding Report.Uterus.MyometriumThickeningDiffuse}" Margin="0,0,16,0"/>
                                        <CheckBox Content="结节" IsChecked="{Binding Report.Uterus.MyometriumThickeningNodule}" Margin="0,0,16,0" x:Name="CbNodule"/>
                                    </StackPanel>

                                    <!-- Nodule Details -->
                                    <Border Background="{StaticResource Brush.AccentLight}" CornerRadius="8" Padding="12" Margin="0,8,0,0" Visibility="{Binding IsChecked, ElementName=CbNodule, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <TextBlock Text="结节详情" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{StaticResource Brush.Accent}"/>
                                            
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="数量：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                                                <ComboBox SelectedValue="{Binding Report.Uterus.NoduleCount, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Grid.Column="1">
                                                     <ComboBoxItem Content="单发"/>
                                                     <ComboBoxItem Content="多发"/>
                                                </ComboBox>
                                                
                                                <TextBlock Text="类型：" Style="{StaticResource Text.Label}" Grid.Column="3"/>
                                                <ComboBox SelectedValue="{Binding Report.Uterus.NoduleType, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Grid.Column="4">
                                                     <ComboBoxItem Content="肌壁间"/>
                                                     <ComboBoxItem Content="浆膜下"/>
                                                     <ComboBoxItem Content="黏膜下"/>
                                                     <ComboBoxItem Content="阔韧带"/>
                                                     <ComboBoxItem Content="宫颈"/>
                                                </ComboBox>
                                            </Grid>

                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="位置：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                                                <ComboBox SelectedValue="{Binding Report.Uterus.NoduleLocation, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Grid.Column="1" IsEditable="True">
                                                     <ComboBoxItem Content="前壁"/>
                                                     <ComboBoxItem Content="后壁"/>
                                                     <ComboBoxItem Content="宫底"/>
                                                     <ComboBoxItem Content="左侧壁"/>
                                                     <ComboBoxItem Content="右侧壁"/>
                                                </ComboBox>
                                            </Grid>

                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="大小：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                                                <StackPanel Orientation="Horizontal" Grid.Column="1">
                                                    <TextBox helpers:TextBoxHelpers.IsNumeric="True" Text="{Binding Report.Uterus.NoduleLength, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                                    <TextBlock Text="×" Margin="4,0"/>
                                                    <TextBox helpers:TextBoxHelpers.IsNumeric="True" Text="{Binding Report.Uterus.NoduleWidth, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                                    <TextBlock Text="×" Margin="4,0"/>
                                                    <TextBox helpers:TextBoxHelpers.IsNumeric="True" Text="{Binding Report.Uterus.NoduleHeight, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                                    <TextBlock Text="cm" Style="{StaticResource Text.Unit}"/>
                                                </StackPanel>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="回声：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                                                <ComboBox SelectedValue="{Binding Report.Uterus.NoduleEcho, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Grid.Column="1">
                                                     <ComboBoxItem Content="低回声"/>
                                                     <ComboBoxItem Content="等回声"/>
                                                     <ComboBoxItem Content="高回声"/>
                                                     <ComboBoxItem Content="混合回声"/>
                                                </ComboBox>
                                                
                                                <TextBlock Text="边界：" Style="{StaticResource Text.Label}" Grid.Column="3"/>
                                                <ComboBox SelectedValue="{Binding Report.Uterus.NoduleBoundary, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Grid.Column="4">
                                                     <ComboBoxItem Content="清晰"/>
                                                     <ComboBoxItem Content="不清"/>
                                                </ComboBox>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- 子宫内膜 -->
                        <Border Background="#F0F7FF" CornerRadius="8" Padding="16,12" Margin="0,20,0,20">
                            <TextBlock Text="子宫内膜" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource Brush.Primary}"/>
                        </Border>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="内膜厚度：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                <TextBox helpers:TextBoxHelpers.IsNumeric="True" Text="{Binding Report.Endometrium.Thickness, UpdateSourceTrigger=PropertyChanged}" Width="60">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Report.Endometrium.CannotMeasure}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <TextBlock Text="cm" Style="{StaticResource Text.Unit}" Margin="4,0,12,0"/>
                                <TextBlock Text="|" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <CheckBox Content="无法测量" IsChecked="{Binding Report.Endometrium.CannotMeasure}" Margin="0"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" FontStyle="Italic" Margin="0,0,0,20" TextWrapping="Wrap">
                            <Run Text="【注：如果存在宫腔积液，应分别测量子宫前后壁单层的内膜厚度并相加；存在宫腔病变时，应记录包含病变在内的子宫内膜总厚度；但病变为黏膜下肌瘤时，测量内膜厚度不应包括黏膜下肌瘤；如果内膜与肌层分界面不清楚，应描述为"/>
                            <Run Text="&quot;无法测量&quot;"/>
                            <Run Text="】"/>
                        </TextBlock>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="内膜回声：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                <RadioButton GroupName="EndoEcho" Content="低回声" IsChecked="{Binding Report.Endometrium.EchoType, Converter={StaticResource RadioBoolConverter}, ConverterParameter=低回声}"/>
                                <RadioButton GroupName="EndoEcho" Content="等回声" IsChecked="{Binding Report.Endometrium.EchoType, Converter={StaticResource RadioBoolConverter}, ConverterParameter=等回声}"/>
                                <RadioButton GroupName="EndoEcho" Content="高回声" IsChecked="{Binding Report.Endometrium.EchoType, Converter={StaticResource RadioBoolConverter}, ConverterParameter=高回声}"/>
                            </WrapPanel>
                        </Grid>

                        <TextBlock Text="回声是否均匀（单选）：" Style="{StaticResource Text.Label}" Margin="0,0,0,8"/>
                        <StackPanel Margin="0,0,0,20">
                            <RadioButton GroupName="EndoUniformity" Content="均匀" IsChecked="{Binding Report.Endometrium.EchoUniform}" Margin="0,0,0,8"/>
                            <StackPanel>
                                <RadioButton GroupName="EndoUniformity" Content="不均匀" IsChecked="{Binding Report.Endometrium.EchoNonUniform}" x:Name="RbEndoNonUniform"/>
                                <StackPanel Margin="24,8,0,0" Visibility="{Binding IsChecked, ElementName=RbEndoNonUniform, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="不均匀类型（可多选）：" Style="{StaticResource Text.LabelSecondary}" Margin="0,0,0,8"/>
                                    <WrapPanel>
                                        <CheckBox Content="未见囊样结构" IsChecked="{Binding Report.Endometrium.NonUniformNoCyst}" Margin="0,0,16,0"/>
                                        <CheckBox Content="可见形态规则的囊样结构" IsChecked="{Binding Report.Endometrium.NonUniformRegularCyst}" Margin="0,0,16,0"/>
                                        <CheckBox Content="可见不规则的囊样结构" IsChecked="{Binding Report.Endometrium.NonUniformIrregularCyst}" Margin="0,0,16,0"/>
                                    </WrapPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="子宫内膜中线（即宫腔线）：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                            <StackPanel Grid.Column="1">
                                <RadioButton GroupName="EndoMid" Content="线性（内膜线平滑、呈线状）" IsChecked="{Binding Report.Endometrium.Midline, Converter={StaticResource RadioBoolConverter}, ConverterParameter=线性}"/>
                                <RadioButton GroupName="EndoMid" Content="非线性（内膜线不平滑、呈波状）" IsChecked="{Binding Report.Endometrium.Midline, Converter={StaticResource RadioBoolConverter}, ConverterParameter=非线性}"/>
                                <RadioButton GroupName="EndoMid" Content="不规则（内膜线回声中断）" IsChecked="{Binding Report.Endometrium.Midline, Converter={StaticResource RadioBoolConverter}, ConverterParameter=不规则}"/>
                                <RadioButton GroupName="EndoMid" Content="未显示（内膜线显示不清）" IsChecked="{Binding Report.Endometrium.Midline, Converter={StaticResource RadioBoolConverter}, ConverterParameter=未显示}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="子宫结合带（位于子宫内膜与肌层的交界面，呈低回声）：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                            <WrapPanel Grid.Column="1">
                                <RadioButton GroupName="EndoJZ" Content="规则" IsChecked="{Binding Report.Endometrium.JunctionalZone, Converter={StaticResource RadioBoolConverter}, ConverterParameter=规则}"/>
                                <RadioButton GroupName="EndoJZ" Content="不规则" IsChecked="{Binding Report.Endometrium.JunctionalZone, Converter={StaticResource RadioBoolConverter}, ConverterParameter=不规则}"/>
                                <RadioButton GroupName="EndoJZ" Content="中断" IsChecked="{Binding Report.Endometrium.JunctionalZone, Converter={StaticResource RadioBoolConverter}, ConverterParameter=中断}"/>
                                <RadioButton GroupName="EndoJZ" Content="未显示" IsChecked="{Binding Report.Endometrium.JunctionalZone, Converter={StaticResource RadioBoolConverter}, ConverterParameter=未显示}"/>
                            </WrapPanel>
                        </Grid>

                        <!-- 子宫内膜 CDFI (血流) -->
                        <Border Background="#F0F7FF" CornerRadius="8" Padding="16,12" Margin="0,20,0,20">
                            <TextBlock Text="子宫内膜 CDFI (血流)" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource Brush.Primary}"/>
                        </Border>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
