<Window x:Class="SURS.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SURS.App"
        xmlns:converters="clr-namespace:SURS.App.Converters"
        xmlns:helpers="clr-namespace:SURS.App.Helpers"
        xmlns:controls="clr-namespace:SURS.App.Controls"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="SURS 妇科超声结构化报告系统" Height="950" Width="1800"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F8F9FA" FontFamily="Segoe UI, Microsoft YaHei UI, sans-serif"
        PreviewKeyDown="Window_PreviewKeyDown"
        Loaded="Window_Loaded">

    <!-- 所有公共资源已移至 App.xaml，此处不再需要 Window.Resources -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <controls:AppHeader Grid.Row="0"/>

        <!-- Main Content - Split View: Form and Preview -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="5" x:Name="SplitterColumn"> <!-- Splitter -->
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPreviewVisible}" Value="False">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition Width="0.75*" MinWidth="300" MaxWidth="1000" x:Name="PreviewColumn">
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="0.75*"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPreviewVisible}" Value="False">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>

            <!-- Left: Form -->
            <ScrollViewer Grid.Column="0" Padding="0,40" Background="{StaticResource Brush.Background}" Style="{StaticResource ModernScrollViewer}">
                <StackPanel MaxWidth="1000" HorizontalAlignment="Center">

                <!-- 报告头部与基础信息 -->
                <controls:ReportHeaderSection/>

                <!-- 模板选择 -->
                <controls:TemplateSelection/>

                <!-- 子宫部分 -->
                <controls:UterusSection/>

                <!-- 子宫内膜部分 -->
                <controls:EndometriumSection/>

                <!-- 卵巢与附件部分 -->
                <controls:AdnexaSection/>

                <!-- Findings Details (Conditional) -->
                
                <!-- 合并积液 -->
                <controls:FluidSection/>

                <!-- 结论与备注区 -->
                <controls:ConclusionSection/>

                <Border Height="60"/>

                </StackPanel>
            </ScrollViewer>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" 
                         HorizontalAlignment="Stretch" 
                         Background="{StaticResource Brush.Border}" 
                         Width="5"
                         ShowsPreview="True">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPreviewVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!-- Right: Preview Panel -->
            <controls:PreviewPanel Grid.Column="2"/>
        </Grid>

        <!-- Footer -->
        <controls:AppFooter Grid.Row="2"/>

    </Grid>
</Window>
