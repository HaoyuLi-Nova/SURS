<Window x:Class="SURS.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SURS.App"
        mc:Ignorable="d"
        Title="SURS 超声报告系统" Height="900" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA" FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Color Palette -->
        <Color x:Key="PrimaryColorBase">#0078D4</Color>
        <Color x:Key="PrimaryDarkColorBase">#005A9E</Color>
        <Color x:Key="SecondaryColorBase">#2B88D8</Color>
        
        <SolidColorBrush x:Key="PrimaryColor" Color="{StaticResource PrimaryColorBase}"/>
        <SolidColorBrush x:Key="PrimaryDarkColor" Color="{StaticResource PrimaryDarkColorBase}"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="{StaticResource SecondaryColorBase}"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#323130"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#605E5C"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E1DFDD"/>

        <!-- Card Style (GroupBox replacement) -->
        <Style x:Key="CardStyle" TargetType="ContentControl">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{StaticResource BorderColor}" 
                                BorderThickness="1" 
                                CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="2" BlurRadius="10" Opacity="0.05"/>
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section Title Style -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Modern TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource SecondaryColor}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource PrimaryColor}"/>
                                <Setter Property="BorderThickness" TargetName="border" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label Style -->
        <Style TargetType="TextBlock" x:Key="LabelText">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Modern CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="checkboxBorder" Width="20" Height="20" CornerRadius="4" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Background="White" Margin="0,0,8,0">
                                <Path x:Name="checkMark" Data="M4,10 L8,14 L16,6" Stroke="White" StrokeThickness="2" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkboxBorder" Property="Background" Value="{StaticResource PrimaryColor}"/>
                                <Setter TargetName="checkboxBorder" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkboxBorder" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryDarkColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryColor}" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <!-- Icon Placeholder -->
                    <Border Width="32" Height="32" CornerRadius="16" Background="White" Margin="0,0,15,0">
                        <TextBlock Text="S" Foreground="{StaticResource PrimaryColor}" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="SURS 超声结构化报告系统" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding Source={x:Static system:DateTime.Now}, StringFormat='yyyy-MM-dd'}" Foreground="White" Opacity="0.8" VerticalAlignment="Center" 
                           xmlns:system="clr-namespace:System;assembly=mscorlib"/>
            </Grid>
        </Border>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" Padding="40,30">
            <StackPanel MaxWidth="1000" HorizontalAlignment="Center">
                
                <!-- 1. 卵巢所见 -->
                <ContentControl Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="1. 卵巢所见" Style="{StaticResource SectionTitle}" Margin="0"/>
                            <CheckBox Content="双侧卵巢正常" IsChecked="{Binding Report.IsNormal}" FontWeight="Bold" VerticalAlignment="Center" Margin="0"/>
                        </Grid>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Ovary -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="左侧卵巢 (Left Ovary)" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Size -->
                                    <TextBlock Text="大小 (L×W×H):" Style="{StaticResource LabelText}" Grid.Row="0" Grid.Column="0"/>
                                    <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1">
                                        <TextBox Text="{Binding Report.LeftOvary.Length}" Width="50"/>
                                        <TextBlock Text="×" Margin="5,0" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding Report.LeftOvary.Width}" Width="50"/>
                                        <TextBlock Text="×" Margin="5,0" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding Report.LeftOvary.Height}" Width="50"/>
                                    </StackPanel>
                                    <TextBlock Text="cm" Style="{StaticResource LabelText}" Grid.Row="0" Grid.Column="2"/>

                                    <!-- Cyst Count -->
                                    <TextBlock Text="囊肿数量:" Style="{StaticResource LabelText}" Grid.Row="2" Grid.Column="0"/>
                                    <TextBox Text="{Binding Report.LeftOvary.CystCount}" Width="50" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Left"/>

                                    <!-- Max Diameter -->
                                    <TextBlock Text="最大径:" Style="{StaticResource LabelText}" Grid.Row="4" Grid.Column="0"/>
                                    <StackPanel Orientation="Horizontal" Grid.Row="4" Grid.Column="1">
                                        <TextBox Text="{Binding Report.LeftOvary.MaxCystDiameter}" Width="60"/>
                                        <TextBlock Text="cm" Style="{StaticResource LabelText}" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- Divider -->
                            <Border Grid.Column="1" Width="1" Background="{StaticResource BorderColor}" Margin="10,0"/>

                            <!-- Right Ovary -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="右侧卵巢 (Right Ovary)" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Size -->
                                    <TextBlock Text="大小 (L×W×H):" Style="{StaticResource LabelText}" Grid.Row="0" Grid.Column="0"/>
                                    <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1">
                                        <TextBox Text="{Binding Report.RightOvary.Length}" Width="50"/>
                                        <TextBlock Text="×" Margin="5,0" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding Report.RightOvary.Width}" Width="50"/>
                                        <TextBlock Text="×" Margin="5,0" VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding Report.RightOvary.Height}" Width="50"/>
                                    </StackPanel>
                                    <TextBlock Text="cm" Style="{StaticResource LabelText}" Grid.Row="0" Grid.Column="2"/>

                                    <!-- Cyst Count -->
                                    <TextBlock Text="囊肿数量:" Style="{StaticResource LabelText}" Grid.Row="2" Grid.Column="0"/>
                                    <TextBox Text="{Binding Report.RightOvary.CystCount}" Width="50" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Left"/>

                                    <!-- Max Diameter -->
                                    <TextBlock Text="最大径:" Style="{StaticResource LabelText}" Grid.Row="4" Grid.Column="0"/>
                                    <StackPanel Orientation="Horizontal" Grid.Row="4" Grid.Column="1">
                                        <TextBox Text="{Binding Report.RightOvary.MaxCystDiameter}" Width="60"/>
                                        <TextBlock Text="cm" Style="{StaticResource LabelText}" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ContentControl>

                <!-- Findings Selection -->
                <ContentControl Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="异常发现类型 (可多选)" Style="{StaticResource SectionTitle}"/>
                        <WrapPanel>
                            <CheckBox Content="单房囊肿" IsChecked="{Binding Report.HasUnilocularCyst}"/>
                            <CheckBox Content="多房囊肿" IsChecked="{Binding Report.HasMultilocularCyst}"/>
                            <CheckBox Content="实性成分囊肿" IsChecked="{Binding Report.HasSolidCyst}"/>
                            <CheckBox Content="实性肿物" IsChecked="{Binding Report.HasSolidMass}"/>
                            <CheckBox Content="盆腔积液" IsChecked="{Binding Report.HasFluid}"/>
                        </WrapPanel>
                    </StackPanel>
                </ContentControl>

                <!-- 2. 单房囊肿 -->
                <ContentControl Style="{StaticResource CardStyle}" Visibility="{Binding Report.HasUnilocularCyst, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="2. 单房囊肿详细信息" Style="{StaticResource SectionTitle}"/>
                        
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="病灶大小:" Style="{StaticResource LabelText}"/>
                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                <TextBox Text="{Binding Report.UnilocularCyst.Length}" Width="60"/>
                                <TextBlock Text="×" Margin="5,0" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Report.UnilocularCyst.Width}" Width="60"/>
                                <TextBlock Text="×" Margin="5,0" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Report.UnilocularCyst.Height}" Width="60"/>
                                <TextBlock Text="cm" Style="{StaticResource LabelText}" Margin="5,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="位置:" Style="{StaticResource LabelText}" Grid.Column="0"/>
                            <TextBox Text="{Binding Report.UnilocularCyst.Location}" Grid.Column="1" Margin="0,0,20,0"/>
                            
                            <CheckBox Content="单纯性囊肿" IsChecked="{Binding Report.UnilocularCyst.IsSimple}" Grid.Column="2" Grid.ColumnSpan="2"/>
                        </Grid>

                        <WrapPanel Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,10">
                                <TextBlock Text="边界:" Style="{StaticResource LabelText}"/>
                                <TextBox Text="{Binding Report.UnilocularCyst.Boundary}" Width="100"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,10">
                                <TextBlock Text="声影:" Style="{StaticResource LabelText}"/>
                                <TextBox Text="{Binding Report.UnilocularCyst.Shadow}" Width="80"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,10">
                                <TextBlock Text="血流评分 (1-4):" Style="{StaticResource LabelText}"/>
                                <TextBox Text="{Binding Report.UnilocularCyst.BloodFlowScore}" Width="50"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </ContentControl>

                <!-- 3. 多房囊肿 -->
                <ContentControl Style="{StaticResource CardStyle}" Visibility="{Binding Report.HasMultilocularCyst, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="3. 多房囊肿详细信息" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="病灶大小:" Style="{StaticResource LabelText}"/>
                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                <TextBox Text="{Binding Report.MultilocularCyst.Length}" Width="60"/>
                                <TextBlock Text="×" Margin="5,0" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Report.MultilocularCyst.Width}" Width="60"/>
                                <TextBlock Text="×" Margin="5,0" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Report.MultilocularCyst.Height}" Width="60"/>
                                <TextBlock Text="cm" Style="{StaticResource LabelText}" Margin="5,0,0,0"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="位置:" Style="{StaticResource LabelText}" Grid.Column="0"/>
                            <TextBox Text="{Binding Report.MultilocularCyst.Location}" Grid.Column="1" Margin="0,0,20,0"/>
                            
                            <TextBlock Text="血流评分:" Style="{StaticResource LabelText}" Grid.Column="2"/>
                            <TextBox Text="{Binding Report.MultilocularCyst.BloodFlowScore}" Grid.Column="3" Width="50" HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                </ContentControl>

                <!-- 4. 实性成分囊肿 -->
                <ContentControl Style="{StaticResource CardStyle}" Visibility="{Binding Report.HasSolidCyst, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="4. 实性成分囊肿详细信息" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="整体大小:" Style="{StaticResource LabelText}"/>
                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                <TextBox Text="{Binding Report.SolidCyst.Length}" Width="60"/>
                                <TextBlock Text="×" Margin="5,0" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Report.SolidCyst.Width}" Width="60"/>
                                <TextBlock Text="×" Margin="5,0" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Report.SolidCyst.Height}" Width="60"/>
                                <TextBlock Text="cm" Style="{StaticResource LabelText}" Margin="5,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="#F3F9FD" BorderBrush="{StaticResource SecondaryColor}" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,10,0,0">
                            <StackPanel>
                                <CheckBox Content="存在乳头状突起 (Papillary Projections)" IsChecked="{Binding Report.SolidCyst.HasPapillary}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                
                                <Grid Visibility="{Binding Report.SolidCyst.HasPapillary, Converter={StaticResource BoolToVis}}" Margin="25,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Text="乳头数量:" Style="{StaticResource LabelText}" Grid.Column="0"/>
                                    <TextBox Text="{Binding Report.SolidCyst.PapillaryCount}" Grid.Column="1" Margin="0,0,20,0"/>
                                    
                                    <TextBlock Text="最大高度:" Style="{StaticResource LabelText}" Grid.Column="2"/>
                                    <StackPanel Orientation="Horizontal" Grid.Column="3">
                                        <TextBox Text="{Binding Report.SolidCyst.PapillaryHeightVal}" Width="60"/>
                                        <TextBlock Text="cm" Style="{StaticResource LabelText}" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ContentControl>

                <!-- 5. 实性肿物 -->
                <ContentControl Style="{StaticResource CardStyle}" Visibility="{Binding Report.HasSolidMass, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="5. 实性肿物详细信息" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="肿物大小:" Style="{StaticResource LabelText}"/>
                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                <TextBox Text="{Binding Report.SolidMass.Length}" Width="60"/>
                                <TextBlock Text="×" Margin="5,0" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Report.SolidMass.Width}" Width="60"/>
                                <TextBlock Text="×" Margin="5,0" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Report.SolidMass.Height}" Width="60"/>
                                <TextBlock Text="cm" Style="{StaticResource LabelText}" Margin="5,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <WrapPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,30,10">
                                <TextBlock Text="回声类型:" Style="{StaticResource LabelText}"/>
                                <TextBox Text="{Binding Report.SolidMass.EchoType}" Width="120"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,30,10">
                                <TextBlock Text="回声均匀性:" Style="{StaticResource LabelText}"/>
                                <TextBox Text="{Binding Report.SolidMass.EchoUniformity}" Width="120"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </ContentControl>

                <!-- 6. 积液 -->
                <ContentControl Style="{StaticResource CardStyle}" Visibility="{Binding Report.HasFluid, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="6. 盆腔积液 (Fluid)" Style="{StaticResource SectionTitle}"/>
                        <ItemsControl ItemsSource="{Binding Report.FluidLocations}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FAFAFA" BorderBrush="#EEEEEE" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,10,10" Width="220">
                                        <StackPanel>
                                            <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Name}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                            <StackPanel Orientation="Horizontal" Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="深度:" Style="{StaticResource LabelText}" FontSize="12"/>
                                                <TextBox Text="{Binding Depth}" Width="50" Height="26" FontSize="12"/>
                                                <TextBlock Text="cm" Style="{StaticResource LabelText}" FontSize="12" Margin="5,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ContentControl>

                <!-- O-RADS Conclusion -->
                <ContentControl Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="O-RADS 分级结论" Style="{StaticResource SectionTitle}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBlock Text="请选择分级:" Style="{StaticResource LabelText}" FontSize="16"/>
                            <ComboBox SelectedValue="{Binding Report.ORadsScore}" Width="200" Height="36" SelectedValuePath="Content" FontSize="16" VerticalContentAlignment="Center" Margin="10,0,0,0">
                                <ComboBoxItem Content="O-RADS 0 - 评估不完全"/>
                                <ComboBoxItem Content="O-RADS 1 - 生理类"/>
                                <ComboBoxItem Content="O-RADS 2 - 几乎确定良性"/>
                                <ComboBoxItem Content="O-RADS 3 - 低风险"/>
                                <ComboBoxItem Content="O-RADS 4 - 中等风险"/>
                                <ComboBoxItem Content="O-RADS 5 - 高风险"/>
                            </ComboBox>
                        </StackPanel>
                        <TextBlock Text="* 请根据 US O-RADS 指南进行最终判定" Foreground="#999" FontSize="12" Margin="0,10,0,0"/>
                    </StackPanel>
                </ContentControl>

                <!-- Spacer -->
                <Border Height="50"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Floating Action Button Area / Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="重置表单" Background="Transparent" Foreground="{StaticResource TextSecondary}" Margin="0,0,10,0" Padding="20,10" BorderThickness="0" Cursor="Hand"/>
                <Button Content="导出 PDF 报告" Style="{StaticResource PrimaryButton}" Command="{Binding ExportPdfCommand}">
                    <Button.Effect>
                        <DropShadowEffect Color="{StaticResource PrimaryColorBase}" Direction="270" ShadowDepth="4" BlurRadius="10" Opacity="0.3"/>
                    </Button.Effect>
                </Button>
            </StackPanel>
        </Border>

