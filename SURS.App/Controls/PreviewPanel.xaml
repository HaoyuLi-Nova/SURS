<UserControl x:Class="SURS.App.Controls.PreviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#E9ECEF" BorderBrush="{StaticResource Brush.BorderLight}" BorderThickness="1,0,0,0" Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVis}}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Preview Header -->
            <Border Grid.Row="0" Background="{StaticResource Brush.Primary}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="📄 报告与预览" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding IsUpdatingPreview, Converter={StaticResource BoolToVis}}" 
                                 Margin="12,0,0,0" 
                                 Foreground="White" 
                                 FontSize="12" 
                                 Opacity="0.9"
                                 VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="(更新中...)"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUpdatingPreview}" Value="False">
                                            <Setter Property="Text" Value=""/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="12,0,0,0" 
                                 Foreground="White" 
                                 FontSize="11" 
                                 Opacity="0.85"
                                 VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="缩放: {0:F0}%">
                                    <Binding Path="PreviewZoomPercent"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="🔍+" 
                               Command="{Binding ZoomInPreviewCommand}" 
                               Background="Transparent" 
                               Foreground="White" 
                               BorderThickness="0" 
                               Padding="8,4" 
                               Cursor="Hand"
                               ToolTip="放大"
                               FontSize="14"
                               Margin="0,0,4,0"/>
                        <Button Content="🔍-" 
                               Command="{Binding ZoomOutPreviewCommand}" 
                               Background="Transparent" 
                               Foreground="White" 
                               BorderThickness="0" 
                               Padding="8,4" 
                               Cursor="Hand"
                               ToolTip="缩小"
                               FontSize="14"
                               Margin="0,0,4,0"/>
                        <Button Content="↻" 
                               Command="{Binding ResetZoomPreviewCommand}" 
                               Background="Transparent" 
                               Foreground="White" 
                               BorderThickness="0" 
                               Padding="8,4" 
                               Cursor="Hand"
                               ToolTip="重置缩放"
                               FontSize="14"
                               Margin="0,0,8,0"/>
                        <Button Content="✕" 
                               Command="{Binding TogglePreviewCommand}"
                               Background="Transparent" 
                               Foreground="White" 
                               BorderThickness="0" 
                               Padding="8,4" 
                               Cursor="Hand"
                               ToolTip="关闭预览"
                               FontSize="16"
                               FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="0">
                <TabItem Header="报告编辑" FontSize="14">
                    <ScrollViewer Style="{StaticResource ModernScrollViewer}" VerticalScrollBarVisibility="Auto" Padding="16,12">
                        <StackPanel MaxWidth="920" HorizontalAlignment="Stretch">
                            <TextBlock Text="在此编辑将直接用于导出 PDF 与左侧预览。留空则使用左侧结构化表单自动生成的成文。" 
                                       TextWrapping="Wrap" Foreground="{StaticResource Brush.TextSecondary}" FontSize="12" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Button Content="从结构化填充" Command="{Binding FillNarrativeFromStructureCommand}" Style="{StaticResource Button.Secondary}" Padding="12,6" Margin="0,0,8,0"/>
                                <Button Content="清空手工正文" Command="{Binding ClearManualNarrativeCommand}" Style="{StaticResource Button.Secondary}" Padding="12,6"/>
                            </StackPanel>
                            <TextBlock Text="超声所见" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Report.EditedFindingsText, UpdateSourceTrigger=LostFocus}"
                                     AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     MinHeight="160" Padding="10" FontSize="13" Margin="0,0,0,16"/>
                            <TextBlock Text="超声提示" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding Report.EditedImpressionText, UpdateSourceTrigger=LostFocus}"
                                     AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     MinHeight="120" Padding="10" FontSize="13"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="PDF 预览" FontSize="14">
                    <ScrollViewer x:Name="PreviewScrollViewer" 
                                 Style="{StaticResource ModernScrollViewer}"
                                 VerticalScrollBarVisibility="Auto" 
                                 HorizontalScrollBarVisibility="Auto" 
                                 Padding="30"
                                 PreviewMouseWheel="PreviewScrollViewer_PreviewMouseWheel"
                                 MouseLeftButtonDown="PreviewScrollViewer_MouseLeftButtonDown"
                                 MouseLeftButtonUp="PreviewScrollViewer_MouseLeftButtonUp"
                                 MouseMove="PreviewScrollViewer_MouseMove">
                        <Grid>
                            <Border Background="White" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,30">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="4" BlurRadius="20" Opacity="0.2"/>
                                </Border.Effect>
                                <Image x:Name="PreviewImageControl"
                                       Source="{Binding PreviewImage}" 
                                       Stretch="Uniform">
                                    <Image.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding PreviewZoom}" ScaleY="{Binding PreviewZoom}"/>
                                    </Image.LayoutTransform>
                                </Image>
                            </Border>
                            
                            <TextBlock Text="预览将在您输入数据后自动生成" 
                                     HorizontalAlignment="Center" 
                                     VerticalAlignment="Center"
                                     Foreground="{StaticResource Brush.TextSecondary}"
                                     FontSize="14"
                                     TextAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PreviewImage}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
