<UserControl x:Class="SURS.App.Controls.PreviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#E9ECEF" BorderBrush="{StaticResource Brush.BorderLight}" BorderThickness="1,0,0,0" Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVis}}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Preview Header -->
            <Border Grid.Row="0" Background="{StaticResource Brush.Primary}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="📄 实时预览" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding IsUpdatingPreview, Converter={StaticResource BoolToVis}}" 
                                 Margin="12,0,0,0" 
                                 Foreground="White" 
                                 FontSize="12" 
                                 Opacity="0.9"
                                 VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="(更新中...)"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUpdatingPreview}" Value="False">
                                            <Setter Property="Text" Value=""/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="12,0,0,0" 
                                 Foreground="White" 
                                 FontSize="11" 
                                 Opacity="0.85"
                                 VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="缩放: {0:F0}%">
                                    <Binding Path="PreviewZoomPercent"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="🔍+" 
                               Command="{Binding ZoomInPreviewCommand}" 
                               Background="Transparent" 
                               Foreground="White" 
                               BorderThickness="0" 
                               Padding="8,4" 
                               Cursor="Hand"
                               ToolTip="放大"
                               FontSize="14"
                               Margin="0,0,4,0"/>
                        <Button Content="🔍-" 
                               Command="{Binding ZoomOutPreviewCommand}" 
                               Background="Transparent" 
                               Foreground="White" 
                               BorderThickness="0" 
                               Padding="8,4" 
                               Cursor="Hand"
                               ToolTip="缩小"
                               FontSize="14"
                               Margin="0,0,4,0"/>
                        <Button Content="↻" 
                               Command="{Binding ResetZoomPreviewCommand}" 
                               Background="Transparent" 
                               Foreground="White" 
                               BorderThickness="0" 
                               Padding="8,4" 
                               Cursor="Hand"
                               ToolTip="重置缩放"
                               FontSize="14"
                               Margin="0,0,8,0"/>
                        <Button Content="✕" 
                               Command="{Binding TogglePreviewCommand}"
                               Background="Transparent" 
                               Foreground="White" 
                               BorderThickness="0" 
                               Padding="8,4" 
                               Cursor="Hand"
                               ToolTip="关闭预览"
                               FontSize="16"
                               FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Preview Content -->
            <ScrollViewer x:Name="PreviewScrollViewer" 
                         Grid.Row="1" 
                         Style="{StaticResource ModernScrollViewer}"
                         VerticalScrollBarVisibility="Auto" 
                         HorizontalScrollBarVisibility="Auto" 
                         Padding="30"
                         PreviewMouseWheel="PreviewScrollViewer_PreviewMouseWheel"
                         MouseLeftButtonDown="PreviewScrollViewer_MouseLeftButtonDown"
                         MouseLeftButtonUp="PreviewScrollViewer_MouseLeftButtonUp"
                         MouseMove="PreviewScrollViewer_MouseMove">
                <Grid>
                    <Border Background="White" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,30">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="4" BlurRadius="20" Opacity="0.2"/>
                        </Border.Effect>
                        <Image x:Name="PreviewImageControl"
                               Source="{Binding PreviewImage}" 
                               Stretch="Uniform">
                            <Image.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding PreviewZoom}" ScaleY="{Binding PreviewZoom}"/>
                            </Image.LayoutTransform>
                        </Image>
                    </Border>
                    
                    <!-- No Preview Message -->
                    <TextBlock Text="预览将在您输入数据后自动生成" 
                             HorizontalAlignment="Center" 
                             VerticalAlignment="Center"
                             Foreground="{StaticResource Brush.TextSecondary}"
                             FontSize="14"
                             TextAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PreviewImage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>

