<UserControl x:Class="SURS.App.Controls.ReportHeaderSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:SURS.App.Converters">
    <Expander Style="{StaticResource CollapsibleCard}">
        <Expander.Header>
            <StackPanel Orientation="Horizontal">
                <Border Width="4" Height="24" Background="White" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="报告头部与基础信息" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Expander.Header>
        <StackPanel>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="机构名称：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                <StackPanel Orientation="Horizontal" Grid.Column="1">
                    <TextBox Text="{Binding Report.HospitalName, UpdateSourceTrigger=PropertyChanged}" Width="300" Margin="0,0,12,0"/>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="登记号：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                <TextBox Text="{Binding Report.RegistrationNo, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1"/>
                
                <TextBlock Text="序号：" Style="{StaticResource Text.Label}" Grid.Column="3"/>
                <TextBox Text="{Binding Report.SerialNo, UpdateSourceTrigger=PropertyChanged}" Grid.Column="4"/>
            </Grid>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="姓名：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                <TextBox Text="{Binding Report.PatientName, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1"/>
                
                <TextBlock Text="性别：" Style="{StaticResource Text.Label}" Grid.Column="3"/>
                <ComboBox SelectedValue="{Binding Report.Gender, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Grid.Column="4" Height="38" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="女"/>
                    <ComboBoxItem Content="男"/>
                </ComboBox>
                
                <TextBlock Text="年龄：" Style="{StaticResource Text.Label}" Grid.Column="6"/>
                <TextBox Text="{Binding Report.Age, UpdateSourceTrigger=PropertyChanged}" Grid.Column="7"/>
            </Grid>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="科别：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                <TextBox Text="{Binding Report.Department, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1"/>

                <TextBlock Text="门诊号：" Style="{StaticResource Text.Label}" Grid.Column="3"/>
                <TextBox Text="{Binding Report.OutpatientNo, UpdateSourceTrigger=PropertyChanged}" Grid.Column="4"/>
                
                <TextBlock Text="住院号：" Style="{StaticResource Text.Label}" Grid.Column="6"/>
                <TextBox Text="{Binding Report.InpatientNo, UpdateSourceTrigger=PropertyChanged}" Grid.Column="7"/>
            </Grid>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="床位：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                <TextBox Text="{Binding Report.BedNo, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1"/>
                
                <TextBlock Text="申请医师：" Style="{StaticResource Text.Label}" Grid.Column="3"/>
                <TextBox Text="{Binding Report.ApplyingPhysician, UpdateSourceTrigger=PropertyChanged}" Grid.Column="4"/>
            </Grid>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="检查项目：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                <ComboBox SelectedValue="{Binding Report.ExamItem, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Grid.Column="1" Height="38" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="经阴道彩色多普勒超声检查"/>
                    <ComboBoxItem Content="经腹部彩色多普勒超声检查"/>
                </ComboBox>
            </Grid>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="报告标题：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                <TextBlock Text="妇科超声结构化报告" Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </Grid>

            <!-- 末次月经时间 (LMP) -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="末次月经时间 (LMP)：" Style="{StaticResource Text.Label}" Grid.Column="0" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                    <ComboBox ItemsSource="{Binding Report.AvailableYears}" 
                              SelectedValue="{Binding Report.LmpYear}" 
                              Width="100" Height="38" 
                              VerticalContentAlignment="Center" 
                              Margin="0,0,8,0"/>
                    <TextBlock Text="年" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="15"/>
                    
                    <ComboBox ItemsSource="{Binding Report.AvailableMonths}" 
                              SelectedValue="{Binding Report.LmpMonth}" 
                              Width="80" Height="38" 
                              VerticalContentAlignment="Center" 
                              Margin="0,0,8,0"/>
                    <TextBlock Text="月" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="15"/>
                    
                    <ComboBox ItemsSource="{Binding Report.AvailableDays}" 
                              SelectedValue="{Binding Report.LmpDay}" 
                              Width="80" Height="38" 
                              VerticalContentAlignment="Center" 
                              Margin="0,0,8,0"/>
                    <TextBlock Text="日" VerticalAlignment="Center" FontSize="15"/>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="图像：" Style="{StaticResource Text.Label}" Grid.Column="0" VerticalAlignment="Top" Margin="0,8,0,0"/>
                <StackPanel Grid.Column="1">
                    <Button Content="📷 选择图片" Command="{Binding SelectImageCommand}" Style="{StaticResource Button.Secondary}" HorizontalAlignment="Left" Margin="0,0,0,16" FontSize="14"/>
                    <StackPanel Orientation="Horizontal">
                        <ItemsControl ItemsSource="{Binding Report.ImagePaths}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                        <TextBlock Margin="0,0,8,0" VerticalAlignment="Center">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource ImageIndexConverter}">
                                                    <Binding RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                    <Binding/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <Border CornerRadius="4" ClipToBounds="True" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
                                            <Image Source="{Binding}" Height="60" Width="60" Stretch="UniformToFill"/>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Expander>
</UserControl>

