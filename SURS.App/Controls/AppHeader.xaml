<UserControl x:Class="SURS.App.Controls.AppHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:system="clr-namespace:System;assembly=mscorlib">
    <Border Background="{StaticResource Brush.HeaderGradient}" Padding="32,20">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.15"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="44" Height="44" CornerRadius="10" Background="White" Margin="0,0,16,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="2" BlurRadius="4" Opacity="0.1"/>
                    </Border.Effect>
                    <TextBlock Text="S" Foreground="{StaticResource Brush.Primary}" FontWeight="Bold" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="SURS 结构化超声报告" Foreground="White" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="妇科超声结构化报告系统" Foreground="White" FontSize="12" Opacity="0.85" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                <TextBlock Text="{Binding Report.HospitalName}" Foreground="White" FontSize="15" Opacity="0.95" Margin="0,0,24,0" VerticalAlignment="Center" FontWeight="Medium"/>
                
                <!-- Date Display -->
                <Border Background="#20FFFFFF" CornerRadius="16" Padding="16,6" Margin="0,0,16,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Source={x:Static system:DateTime.Now}, StringFormat='yyyy-MM-dd'}" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </Border>

                <!-- Toggle Preview Button -->
                <Button Command="{Binding TogglePreviewCommand}" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        Cursor="Hand"
                        Padding="0"
                        VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" Background="#30FFFFFF" CornerRadius="16" Padding="16,6">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="BtnIcon" Text="✕" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="BtnText" Text="关闭预览" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsPreviewVisible}" Value="False">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#FFFFFF"/>
                                    <Setter TargetName="BtnIcon" Property="Text" Value="👁"/>
                                    <Setter TargetName="BtnIcon" Property="Foreground" Value="{StaticResource Brush.Primary}"/>
                                    <Setter TargetName="BtnText" Property="Text" Value="显示预览"/>
                                    <Setter TargetName="BtnText" Property="Foreground" Value="{StaticResource Brush.Primary}"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

