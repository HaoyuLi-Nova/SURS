<UserControl x:Class="SURS.App.Controls.ORadsResultCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border CornerRadius="10" 
            Padding="16" 
            Margin="0,0,0,16"
            BorderThickness="2"
            Visibility="{Binding Report.AutoORadsResult, Converter={StaticResource NullToVis}}">
        <Border.Background>
            <Binding Path="Report.AutoORadsResult" Converter="{StaticResource ORadsLevelToBgColor}"/>
        </Border.Background>
        <Border.BorderBrush>
            <Binding Path="Report.AutoORadsResult" Converter="{StaticResource ORadsLevelToBorderColor}"/>
        </Border.BorderBrush>
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="🤖 自动分级建议：" 
                           FontWeight="SemiBold" 
                           FontSize="15"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0">
                    <TextBlock.Foreground>
                        <Binding Path="Report.AutoORadsResult" Converter="{StaticResource ORadsLevelToColor}"/>
                    </TextBlock.Foreground>
                </TextBlock>
                <Border Background="White" 
                        CornerRadius="6" 
                        Padding="10,6"
                        BorderThickness="2">
                    <Border.BorderBrush>
                        <Binding Path="Report.AutoORadsResult" Converter="{StaticResource ORadsLevelToBorderColor}"/>
                    </Border.BorderBrush>
                    <TextBlock Text="{Binding Report.AutoORadsResult.LevelString}" 
                               FontWeight="Bold" 
                               FontSize="18">
                        <TextBlock.Foreground>
                            <Binding Path="Report.AutoORadsResult" Converter="{StaticResource ORadsLevelToColor}"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                </Border>
            </StackPanel>
            <TextBlock Text="{Binding Report.AutoORadsResult.Reason}" 
                       TextWrapping="Wrap"
                       FontSize="13"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       Margin="0,0,0,8"
                       LineHeight="20"/>
            <Border Background="White" 
                    CornerRadius="6" 
                    Padding="12,8"
                    Margin="0,0,0,8"
                    Visibility="{Binding Report.AutoORadsResult.Suggestion, Converter={StaticResource StringToVis}}"
                    BorderBrush="{StaticResource Brush.BorderLight}" 
                    BorderThickness="1">
                <TextBlock TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           FontStyle="Italic"
                           LineHeight="18">
                    <Run Text="💡 提示：" FontWeight="SemiBold" Foreground="{StaticResource Brush.Primary}"/>
                    <Run Text="{Binding Report.AutoORadsResult.Suggestion}"/>
                </TextBlock>
            </Border>
            <CheckBox Content="✓ 使用自动分级建议" 
                      IsChecked="{Binding Report.UseAutoORads}"
                      FontSize="13"
                      Margin="0,8,0,0"
                      FontWeight="Medium">
                <CheckBox.Foreground>
                    <Binding Path="Report.AutoORadsResult" Converter="{StaticResource ORadsLevelToColor}"/>
                </CheckBox.Foreground>
            </CheckBox>
        </StackPanel>
    </Border>
</UserControl>

