<UserControl x:Class="SURS.App.Controls.AppFooter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" BorderBrush="{StaticResource Brush.BorderLight}" BorderThickness="0,2,0,0" Padding="32,20">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="-2" BlurRadius="10" Opacity="0.05"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="🔄 重置表单" Command="{Binding ResetCommand}" Style="{StaticResource Button.Secondary}" Margin="0,0,16,0"/>
            <Button Content="📄 导出 PDF 报告" Style="{StaticResource Button.Primary}" Command="{Binding ExportPdfCommand}">
                <Button.Effect>
                    <DropShadowEffect Color="#4A90E2" Direction="270" ShadowDepth="4" BlurRadius="16" Opacity="0.25"/>
                </Button.Effect>
            </Button>
        </StackPanel>
    </Border>
</UserControl>

