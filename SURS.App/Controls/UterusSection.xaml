<UserControl x:Class="SURS.App.Controls.UterusSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:SURS.App.Converters"
             xmlns:helpers="clr-namespace:SURS.App.Helpers">
    <Expander Style="{StaticResource CollapsibleCard}" Visibility="{Binding Report.IncludeUterus, Converter={StaticResource BoolToVis}}">
        <Expander.Header>
            <StackPanel Orientation="Horizontal">
                <Border Width="4" Height="24" Background="White" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="子宫部分" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Expander.Header>
        <StackPanel>
            <Border Background="#F0F7FF" CornerRadius="8" Padding="16,12" Margin="0,0,0,20">
                <TextBlock Text="子宫基本声像" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource Brush.Primary}"/>
            </Border>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="子宫位置：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <RadioButton GroupName="UterusPos" Content="前位" IsChecked="{Binding Report.Uterus.Position, Converter={StaticResource RadioBoolConverter}, ConverterParameter=前位}"/>
                    <RadioButton GroupName="UterusPos" Content="后位" IsChecked="{Binding Report.Uterus.Position, Converter={StaticResource RadioBoolConverter}, ConverterParameter=后位}"/>
                    <RadioButton GroupName="UterusPos" Content="中位" IsChecked="{Binding Report.Uterus.Position, Converter={StaticResource RadioBoolConverter}, ConverterParameter=中位}"/>
                </WrapPanel>
            </Grid>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="子宫体大小：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                <StackPanel Orientation="Horizontal" Grid.Column="1">
                    <TextBox helpers:TextBoxHelpers.IsNumeric="True" helpers:TextBoxHelpers.PlaceholderText="长径" Text="{Binding Report.Uterus.Length, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleToStringConverter}}" Width="50"/>
                    <TextBlock Text="×" Margin="4,0"/>
                    <TextBox helpers:TextBoxHelpers.IsNumeric="True" helpers:TextBoxHelpers.PlaceholderText="前后径" Text="{Binding Report.Uterus.APDiameter, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleToStringConverter}}" Width="50"/>
                    <TextBlock Text="×" Margin="4,0"/>
                    <TextBox helpers:TextBoxHelpers.IsNumeric="True" helpers:TextBoxHelpers.PlaceholderText="横径" Text="{Binding Report.Uterus.Width, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleToStringConverter}}" Width="50"/>
                    <TextBlock Text="cm" Style="{StaticResource Text.Unit}" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="子宫颈大小：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                <StackPanel Orientation="Horizontal" Grid.Column="1">
                    <CheckBox Content="测量" IsChecked="{Binding Report.Uterus.ShouldMeasureCervix}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" IsEnabled="{Binding Report.Uterus.ShouldMeasureCervix}">
                        <TextBox helpers:TextBoxHelpers.IsNumeric="True" helpers:TextBoxHelpers.PlaceholderText="长径" Text="{Binding Report.Uterus.CervixLength, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleToStringConverter}}" Width="50"/>
                        <TextBlock Text="×" Margin="4,0"/>
                        <TextBox helpers:TextBoxHelpers.IsNumeric="True" helpers:TextBoxHelpers.PlaceholderText="前后径" Text="{Binding Report.Uterus.CervixAP, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleToStringConverter}}" Width="50"/>
                        <TextBlock Text="cm" Style="{StaticResource Text.Unit}" Margin="4,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="子宫肌层回声：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <WrapPanel VerticalAlignment="Center">
                        <RadioButton GroupName="MyometriumEcho" Content="均匀"
                                     IsChecked="{Binding Report.Uterus.MyometriumEcho, Converter={StaticResource RadioBoolConverter}, ConverterParameter=均匀}"
                                     Margin="0,0,16,0"
                                     PreviewMouseLeftButtonDown="MyometriumEchoRadio_PreviewMouseLeftButtonDown"/>
                        <RadioButton GroupName="MyometriumEcho" Content="不均"
                                     IsChecked="{Binding Report.Uterus.MyometriumEcho, Converter={StaticResource RadioBoolConverter}, ConverterParameter=不均}"
                                     x:Name="RbNonUniform" Margin="0,0,16,0"
                                     PreviewMouseLeftButtonDown="MyometriumEchoRadio_PreviewMouseLeftButtonDown"/>
                    </WrapPanel>
                </StackPanel>
            </Grid>
                
            <!-- Non-uniform Options -->
            <StackPanel Margin="24,8,0,12" Visibility="{Binding IsChecked, ElementName=RbNonUniform, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <CheckBox Content="局限性增厚" IsChecked="{Binding Report.Uterus.MyometriumThickeningFocal}" Margin="0,0,16,0"/>
                    <CheckBox Content="弥漫性增厚" IsChecked="{Binding Report.Uterus.MyometriumThickeningDiffuse}" Margin="0,0,16,0"/>
                    <CheckBox Content="结节" IsChecked="{Binding Report.Uterus.MyometriumThickeningNodule}" Margin="0,0,16,0" x:Name="CbNodule"/>
                </StackPanel>

                <!-- Nodule Details -->
                <Border Background="{StaticResource Brush.AccentLight}" CornerRadius="8" Padding="12" Margin="0,8,0,0" Visibility="{Binding IsChecked, ElementName=CbNodule, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12" LastChildFill="False">
                            <TextBlock Text="结节详情" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent}" DockPanel.Dock="Left"/>
                            <Button Content="添加结节" Style="{StaticResource Button.Primary}" Padding="18,8" FontSize="13" Command="{Binding AddUterusNoduleCommand}" DockPanel.Dock="Right"/>
                        </DockPanel>

                        <!-- 报告方式：只描述较大者 / 全部写出 -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="报告方式：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                <RadioButton GroupName="NoduleReportMode" Content="只描述较大者" IsChecked="{Binding Report.Uterus.ReportOnlyLargestNodule}" Margin="0,0,16,0"/>
                                <RadioButton GroupName="NoduleReportMode" Content="全部写出" IsChecked="{Binding Report.Uterus.ReportOnlyLargestNodule, Converter={StaticResource RadioBoolConverter}, ConverterParameter=False}" Margin="0,0,16,0"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="尚未添加结节。点击“添加结节”开始填写。" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Report.Uterus.Nodules.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TabControl ItemsSource="{Binding Report.Uterus.Nodules}"
                                    SelectedItem="{Binding Report.Uterus.SelectedNodule, Mode=TwoWay}"
                                    AlternationCount="200"
                                    Margin="0,0,0,8">
                            <TabControl.Style>
                                <Style TargetType="TabControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Report.Uterus.Nodules.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TabControl.Style>

                            <TabControl.ItemContainerStyle>
                                <Style TargetType="TabItem">
                                    <Setter Property="Header">
                                        <Setter.Value>
                                            <Binding RelativeSource="{RelativeSource Self}" Path="(ItemsControl.AlternationIndex)" Converter="{StaticResource NoduleTabHeaderConverter}"/>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TabControl.ItemContainerStyle>

                            <TabControl.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="8,10,8,8">
                                        <Button Content="删除此结节" Style="{StaticResource Button.Secondary}" Padding="12,6" FontSize="12" HorizontalAlignment="Right" Margin="0,0,0,12"
                                                Command="{Binding DataContext.RemoveUterusNoduleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="位置：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                                            <ComboBox SelectedValue="{Binding Location, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Grid.Column="1" IsEditable="True">
                                                <ComboBoxItem Content="前壁"/>
                                                <ComboBoxItem Content="后壁"/>
                                                <ComboBoxItem Content="宫底"/>
                                                <ComboBoxItem Content="左侧壁"/>
                                                <ComboBoxItem Content="右侧壁"/>
                                            </ComboBox>
                                        </Grid>

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="大小：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                                <TextBox helpers:TextBoxHelpers.IsNumeric="True" helpers:TextBoxHelpers.PlaceholderText="长径" Text="{Binding Length, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleToStringConverter}}" Width="50"/>
                                                <TextBlock Text="×" Margin="4,0"/>
                                                <TextBox helpers:TextBoxHelpers.IsNumeric="True" helpers:TextBoxHelpers.PlaceholderText="宽径" Text="{Binding Width, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleToStringConverter}}" Width="50"/>
                                                <TextBlock Text="×" Margin="4,0"/>
                                                <TextBox helpers:TextBoxHelpers.IsNumeric="True" helpers:TextBoxHelpers.PlaceholderText="厚径" Text="{Binding Height, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DoubleToStringConverter}}" Width="50"/>
                                                <TextBlock Text="cm" Style="{StaticResource Text.Unit}"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="回声：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                                            <ComboBox SelectedValue="{Binding Echo, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Grid.Column="1" IsEditable="True">
                                                <ComboBoxItem Content="低回声"/>
                                                <ComboBoxItem Content="等回声"/>
                                                <ComboBoxItem Content="高回声"/>
                                            </ComboBox>
                                        </Grid>

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="边界：" Style="{StaticResource Text.Label}" Grid.Column="0"/>
                                            <ComboBox SelectedValue="{Binding Boundary, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Grid.Column="1" IsEditable="True">
                                                <ComboBoxItem Content="规则"/>
                                                <ComboBoxItem Content="不规则"/>
                                            </ComboBox>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <CheckBox Content="外突" IsChecked="{Binding Protrudes}" Margin="0,0,16,0"/>
                                            <CheckBox Content="压迫宫腔" IsChecked="{Binding CompressesCavity}" Margin="0,0,16,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </TabControl.ContentTemplate>
                        </TabControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </Expander>
</UserControl>

